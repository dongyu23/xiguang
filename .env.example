APP_ENV=development
APP_PORT=8080
JWT_SECRET=replace_with_64char_random_string_before_real_deploy_please
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h
ALLOWED_ORIGIN=*

DB_HOST=postgres
DB_PORT=5432
DB_USER=glimmer
DB_PASSWORD=glimmer_dev_password
DB_NAME=glimmer
DB_SSLMODE=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=glimmer_minio
MINIO_SECRET_KEY=glimmer_minio_password
MINIO_BUCKET=glimmer-media
MINIO_USE_SSL=false
MINIO_PRESIGN_UPLOAD_TTL=5m
MINIO_PRESIGN_DOWNLOAD_TTL=5m
MEDIA_MAX_IMAGE_SIZE=10485760
MEDIA_MAX_AUDIO_SIZE=52428800
MEDIA_IMAGE_FORMATS=JPEG,PNG,HEIC,WebP
MEDIA_AUDIO_FORMATS=M4A,AAC,MP3,WAV

AI_PROVIDER=deepseek
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_DEEPSEEK_MODEL=deepseek-chat
AI_MAX_TOKENS=2048
AI_TIMEOUT=60s
AI_DAILY_QUOTA_PER_USER=50

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0
